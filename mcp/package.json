{
  "name": "@commercetools-demo/contenttools-mcp",
  "version": "1.1.5",
  "description": "Content Tools MCP - AI/LangChain/Mastra tools for the CMS service API",
  "type": "module",
  "main": "./ai-sdk/index.js",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./ai-sdk": {
      "types": "./ai-sdk/index.d.ts",
      "import": "./ai-sdk/index.js",
      "require": "./ai-sdk/index.cjs"
    },
    "./langchain": {
      "types": "./langchain/index.d.ts",
      "import": "./langchain/index.js",
      "require": "./langchain/index.cjs"
    }
  },
  "files": [
    "ai-sdk/**/*",
    "langchain/**/*",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf ai-sdk langchain mastra",
    "mcp": "tsx src/modelcontextprotocol/index.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0",
    "@modelcontextprotocol/sdk": ">=1.0.0",
    "ai": "^6.0.0 || ^7.0.0",
    "zod": ">=3.0.0"
  },
  "dependencies": {
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@langchain/core": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ai": "^6.0.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
