{
  "id": "cms-api-environment",
  "name": "CMS API Environment",
  "values": [
    {
      "key": "base_url",
      "value": "http://localhost:8080/service",
      "description": "Base URL for the CMS API service",
      "type": "default",
      "enabled": true
    },
    {
      "key": "project_key",
      "value": "",
      "description": "Project key for x-project-key header (required for fetch endpoints). Set to ct_project_key after authenticating.",
      "type": "default",
      "enabled": true
    },
    {
      "key": "ct_client_id",
      "value": "",
      "description": "CommerceTools client ID for Authenticate Project",
      "type": "default",
      "enabled": true
    },
    {
      "key": "ct_client_secret",
      "value": "",
      "description": "CommerceTools client secret for Authenticate Project",
      "type": "secret",
      "enabled": true
    },
    {
      "key": "ct_project_key",
      "value": "",
      "description": "CommerceTools project key; copy to project_key and bearer_token after auth",
      "type": "default",
      "enabled": true
    },
    {
      "key": "business_unit_key",
      "value": "default",
      "description": "Default business unit key",
      "type": "default",
